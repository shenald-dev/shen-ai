{
    "name": "shen-ai",
    "displayName": "SHEN AI - Coding Agent",
    "description": "A superior multi-agent, multi-provider AI coding assistant with predictive intent, self-evolving prompts, and autonomous feature building.",
    "version": "0.1.0",
    "publisher": "shen-ai",
    "icon": "assets/icon.png",
    "repository": {
        "type": "git",
        "url": "https://github.com/shen-ai/shen-ai"
    },
    "engines": {
        "vscode": "^1.85.0"
    },
    "categories": [
        "AI",
        "Programming Languages",
        "Snippets",
        "Other"
    ],
    "keywords": [
        "ai",
        "coding assistant",
        "agent",
        "multi-agent",
        "chatgpt",
        "claude",
        "autonomous",
        "code generation"
    ],
    "activationEvents": [],
    "main": "./dist/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "shen.openChat",
                "title": "SHEN AI: Open Chat Panel",
                "icon": "$(comment-discussion)"
            },
            {
                "command": "shen.openSettings",
                "title": "SHEN AI: Open Settings",
                "icon": "$(gear)"
            },
            {
                "command": "shen.newTask",
                "title": "SHEN AI: New Task",
                "icon": "$(add)"
            },
            {
                "command": "shen.cancelTask",
                "title": "SHEN AI: Cancel Current Task",
                "icon": "$(debug-stop)"
            },
            {
                "command": "shen.inlineChat",
                "title": "SHEN AI: Inline Chat",
                "icon": "$(comment-discussion)"
            }
        ],
        "viewsContainers": {
            "activitybar": [
                {
                    "id": "shen-ai",
                    "title": "SHEN AI",
                    "icon": "assets/activity-icon.svg"
                }
            ]
        },
        "views": {
            "shen-ai": [
                {
                    "type": "webview",
                    "id": "shen.chatView",
                    "name": "Chat",
                    "icon": "$(comment-discussion)"
                }
            ]
        },
        "menus": {
            "editor/context": [
                {
                    "command": "shen.inlineChat",
                    "when": "editorHasSelection",
                    "group": "shen@1"
                }
            ],
            "view/title": [
                {
                    "command": "shen.newTask",
                    "when": "view == shen.chatView",
                    "group": "navigation@1"
                }
            ]
        },
        "keybindings": [
            {
                "command": "shen.openChat",
                "key": "ctrl+shift+alt+s",
                "mac": "cmd+shift+alt+s"
            },
            {
                "command": "shen.inlineChat",
                "key": "ctrl+shift+alt+a",
                "mac": "cmd+shift+alt+a",
                "when": "editorHasSelection"
            }
        ],
        "configuration": {
            "title": "SHEN AI",
            "properties": {
                "shen.ai.provider": {
                    "type": "string",
                    "enum": [
                        "openai",
                        "anthropic",
                        "google",
                        "ollama",
                        "azure",
                        "groq",
                        "mistral",
                        "custom"
                    ],
                    "default": "anthropic",
                    "description": "AI provider to use"
                },
                "shen.ai.model": {
                    "type": "string",
                    "default": "claude-sonnet-4-20250514",
                    "description": "Model name for the selected provider"
                },
                "shen.ai.openaiApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "OpenAI API key"
                },
                "shen.ai.anthropicApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Anthropic API key"
                },
                "shen.ai.googleApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Google Gemini API key"
                },
                "shen.ai.groqApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Groq API key"
                },
                "shen.ai.mistralApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Mistral API key"
                },
                "shen.ai.azureApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Azure OpenAI API key"
                },
                "shen.ai.azureEndpoint": {
                    "type": "string",
                    "default": "",
                    "description": "Azure OpenAI endpoint URL"
                },
                "shen.ai.ollamaBaseUrl": {
                    "type": "string",
                    "default": "http://localhost:11434",
                    "description": "Ollama base URL"
                },
                "shen.ai.customBaseUrl": {
                    "type": "string",
                    "default": "",
                    "description": "Custom OpenAI-compatible API base URL"
                },
                "shen.ai.customApiKey": {
                    "type": "string",
                    "default": "",
                    "description": "Custom API key"
                },
                "shen.ai.customModel": {
                    "type": "string",
                    "default": "",
                    "description": "Custom model name"
                },
                "shen.ai.temperature": {
                    "type": "number",
                    "default": 0,
                    "minimum": 0,
                    "maximum": 2,
                    "description": "Temperature for AI responses"
                },
                "shen.ai.maxTokens": {
                    "type": "number",
                    "default": 8192,
                    "minimum": 256,
                    "maximum": 128000,
                    "description": "Maximum tokens for AI responses"
                },
                "shen.ai.personality": {
                    "type": "string",
                    "enum": [
                        "mentor",
                        "senior-dev",
                        "hacker",
                        "reviewer",
                        "socratic",
                        "silent-partner"
                    ],
                    "default": "senior-dev",
                    "description": "AI personality style"
                },
                "shen.ai.enablePredictiveIntent": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable predictive intent engine (anticipates your next moves)"
                },
                "shen.ai.enableGhostMode": {
                    "type": "boolean",
                    "default": false,
                    "description": "Enable ghost mode (passively learns your coding style)"
                },
                "shen.ai.enableSelfEvolvingPrompts": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable self-evolving prompts (learns from your corrections)"
                },
                "shen.ai.autoApplyChanges": {
                    "type": "boolean",
                    "default": false,
                    "description": "Automatically apply code changes without confirmation"
                },
                "shen.ai.enableCodeDNAProfiling": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Code DNA Profiling (learns your coding style and adapts AI output)"
                },
                "shen.ai.enableSmartCheckpointRollback": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Smart Checkpoint Rollback (multi-level undo with git integration)"
                },
                "shen.ai.enableBlastRadiusAnalyzer": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Blast Radius Analyzer (shows what files depend on your changes)"
                },
                "shen.ai.enableCodeValidator": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Code Validator (validates AI-generated code for syntax errors before applying)"
                },
                "shen.ai.enableConversationSummarizer": {
                    "type": "boolean",
                    "default": true,
                    "description": "Enable Smart Conversation Summarizer (compresses long conversations to save context tokens)"
                },
                "shen.ai.agentMode": {
                    "type": "string",
                    "enum": [
                        "act",
                        "plan"
                    ],
                    "default": "act",
                    "description": "The current mode of the AI agent (act or plan)"
                },
                "shen.ai.maxContextTokens": {
                    "type": "number",
                    "default": 200000,
                    "description": "Maximum context tokens to send to the AI"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run build",
        "build": "node esbuild.js",
        "watch": "node esbuild.js --watch",
        "lint": "eslint src --ext ts,tsx",
        "package": "vsce package --no-dependencies",
        "publish": "vsce publish --no-dependencies"
    },
    "devDependencies": {
        "@types/node": "^20.11.0",
        "@types/react": "^18.2.48",
        "@types/react-dom": "^18.2.18",
        "@types/vscode": "^1.85.0",
        "@types/vscode-webview": "^1.57.5",
        "@typescript-eslint/eslint-plugin": "^8.60.1",
        "@typescript-eslint/parser": "^8.60.1",
        "autoprefixer": "^10.4.17",
        "esbuild": "^0.19.11",
        "eslint": "^8.56.0",
        "postcss": "^8.4.33",
        "postcss-loader": "^7.3.4",
        "tailwindcss": "^3.4.1",
        "typescript": "^5.3.3"
    },
    "dependencies": {
        "@anthropic-ai/sdk": "^0.36.0",
        "@google/generative-ai": "^0.21.0",
        "@mistralai/mistralai": "^1.3.6",
        "@vscode/codicons": "^0.0.36",
        "@vscode/webview-ui-toolkit": "^1.4.0",
        "groq-sdk": "^0.12.0",
        "ignore": "^6.0.2",
        "ollama": "^0.5.11",
        "openai": "^4.77.0",
        "react": "^18.2.0",
        "react-dom": "^18.2.0",
        "react-markdown": "^9.0.1",
        "rehype-highlight": "^7.0.0",
        "rehype-raw": "^7.0.0",
        "rehype-sanitize": "^6.0.0",
        "remark-gfm": "^4.0.0",
        "tiktoken": "^1.0.18",
        "zustand": "^4.5.0"
    }
}
